rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function for superadmin read access
    function isSuperAdmin() {
      return request.auth.uid == '0IV6GKQazUcp8hqoTsDG9dXIqrA3';
    }

match /public/{uid} {
      allow read: if true;

      match /products/{id} {
        allow read: if true;
      }
}

match /public/{uid} {
      allow read, write: if request.auth != null && (request.auth.uid == uid || isSuperAdmin());

      match /products/{id} {
        allow read, write: if request.auth.uid == uid || isSuperAdmin();
      }
}

    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isSuperAdmin());
      allow write: if request.auth != null && (request.auth.uid == uid || isSuperAdmin());

      match /customers/{id} {
        allow read: if request.auth.uid == uid || isSuperAdmin();
        allow write: if request.auth.uid == uid;
      }

      match /wooOrders/{id} {
        allow read: if request.auth.uid == uid || isSuperAdmin();
        allow write: if request.auth.uid == uid;
      }

      match /pendingOrders/{id} {
        allow read: if request.auth.uid == uid || isSuperAdmin();
        allow write: if request.auth.uid == uid;
      }

       match /devices/{document=**} {
        allow read: if request.auth.uid == uid || isSuperAdmin();
        allow write: if request.auth.uid == uid;
      }

      match /employees/{document=**} {
        allow read: if request.auth.uid == uid || isSuperAdmin();
        allow write: if request.auth.uid == uid;
      }

      match /activityLog/{id} {
        allow read: if request.auth.uid == uid || isSuperAdmin();
        allow write: if request.auth.uid == uid;
      }

      match /products/{id} {
        allow read: if request.auth.uid == uid || isSuperAdmin();
        allow write: if request.auth.uid == uid;

        match /stockHistory/{entryId} {
          allow read: if request.auth.uid == uid || isSuperAdmin();
          allow write: if request.auth.uid == uid;
        }
      }

      match /ingredients/{id} {
        allow read: if request.auth.uid == uid || isSuperAdmin();
        allow write: if request.auth.uid == uid;

        match /stockHistory/{entryId} {
          allow read: if request.auth.uid == uid || isSuperAdmin();
          allow write: if request.auth.uid == uid;
        }
      }

      match /optionTemplates/{id} {
        allow read: if request.auth.uid == uid || isSuperAdmin();
        allow write: if request.auth.uid == uid;
      }

      match /deliveryOrders/{id} {
        allow read: if request.auth.uid == uid || isSuperAdmin();
        allow write: if false;  // Written exclusively by Cloud Function (Admin SDK bypasses rules)
      }

      match /transList/{id} {
        allow read: if request.auth.uid == uid || isSuperAdmin();
        allow write: if request.auth.uid == uid;
      }

      match /stats/{id} {
        allow read: if request.auth.uid == uid || isSuperAdmin();
        allow write: if request.auth.uid == uid;
      }

      match /checkout_sessions/{id} {
        allow read: if request.auth.uid == uid || isSuperAdmin();
        allow write: if request.auth.uid == uid;
      }
      match /subscriptions/{id} {
        allow read: if request.auth.uid == uid || isSuperAdmin();
      }
      match /payments/{id} {
        allow read: if request.auth.uid == uid || isSuperAdmin();
      }
    }

    // Superadmin system logging collections
    match /systemLogs/{id} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && isSuperAdmin();
      allow update, delete: if false;
    }

    match /systemErrors/{id} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && isSuperAdmin();
      allow update, delete: if false;
    }

    match /products/{id} {
      allow read: if true;

      match /prices/{id} {
        allow read: if true;
      }

      match /tax_rates/{id} {
        allow read: if true;
      }
    }
  }
}