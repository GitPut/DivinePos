{
  "compilerOptions": {
    "module": "ESNext",
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true,
    "target": "ESNext",
    "skipLibCheck": true,
    "baseUrl": "./",
    "paths": {
      "assets/*":   ["assets/*"],
      "features/*": ["features/*"],
      "shared/*":   ["shared/*"],
      "services/*": ["services/*"],
      "store/*":    ["store/*"],
      "utils/*":    ["utils/*"],
      "router/*":   ["router/*"],
      "types/*":    ["types/*"]
    }
  },
  "include": ["src", "features", "shared", "services", "store", "utils", "router", "types", "App.tsx"],
  "exclude": [
    "node_modules",
    "dist",
    "web-build",
    "functions"
  ]
}
